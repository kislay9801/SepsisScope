# Downloaded image datasets — Kaggle disease-category folders are named
# "<number>.<name>" (e.g. 0.0.Normal, 11.Severe hypertensive retinopathy).
# Ignore every top-level folder that starts with a digit.
/[0-9]*/

# Data (large image datasets — commit only if small/versioned)
data/
# Named training/test image datasets (not digit-prefixed, so listed explicitly)
HRF/
LES-AV/
testx/

